# .gitattributes
* text=auto
*.sh text eol=lf
*.py text eol=lf
*.tf text eol=lf
*.yml text eol=lf
*.json text eol=lf
README.md text eol=lf
# Default: normalize all text files to LF
* text=auto eol=lf

# Binary files should not be modified
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
*.exe   binary
*.dll   binary
